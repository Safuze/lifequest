// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id             Int      @id @default(autoincrement())
  publicId       String   @unique @default(cuid())
  email          String   @unique
  passwordHash   String?
  oauthProvider  String?
  oauthId        String?
  name           String
  avatar         String?
  avatarBorder   String   @default("none")
  profileBg      String   @default("default")
  level          Int      @default(0)
  xp             Int      @default(0)
  gold           Float    @default(0)
  theme          String   @default("dark")
  createdAt      DateTime @default(now())
  isProfilePublic Boolean @default(true)
  habitSlots     Int @default(10)
  taskSlots      Int @default(20)
  dailyTaskLimit Int @default(10)
  
  goals          Goal[]
  projects       Project[]
  tasks          Task[]
  habits         Habit[]
  sessions       PomodoroSession[]
  achievements   Achievement[]
  transactions   RewardTransaction[]
  inventory      InventoryItem[]
  weeklyReports  WeeklyReport[]
  sentRequests   Friendship[]      @relation("sender")
  receivedRequests Friendship[]    @relation("receiver")
  pomodoroSettings PomodoroSettings?
  notifications Notification[]
  activeBoosters  ActiveBooster[]
  permanentPerks  PermanentPerk[]
}

model Goal {
  id           Int       @id @default(autoincrement())
  userId       Int
  title        String
  category     String
  horizon      String
  deadline     DateTime?
  plannedHours Float?
  spentHours   Float     @default(0)
  progress     Int       @default(0)
  status       String    @default("active")
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks        Task[]
  sessions     PomodoroSession[]

  @@index([userId])
}

model Project {
  id        Int      @id @default(autoincrement())
  userId    Int
  title     String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tasks     Task[]

  @@index([userId])
}

model Task {
  id           Int       @id @default(autoincrement())
  userId       Int
  goalId       Int?
  projectId    Int?
  parentId     Int?
  title        String
  description  String?
  priority     String    @default("medium")
  category     String?
  labels       String[]
  status       String    @default("todo")
  dueDate      DateTime?
  completedAt  DateTime?
  isPinned     Boolean   @default(false)
  isFocusToday Boolean   @default(false)
  timeSpent    Float     @default(0)
  createdAt    DateTime  @default(now())

  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  goal         Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  project      Project?  @relation(fields: [projectId], references: [id], onDelete: SetNull)
  parent       Task?     @relation("subtasks", fields: [parentId], references: [id])
  subtasks     Task[]    @relation("subtasks")
  sessions     PomodoroSession[]

  @@index([userId])
  @@index([goalId])
  @@index([dueDate])
}

model PomodoroSession {
  id              Int       @id @default(autoincrement())
  userId          Int
  taskId          Int?
  goalId          Int?
  plannedDuration Int
  actualDuration  Int       @default(0)
  status          String    @default("active")
  cycleNumber     Int       @default(1)
  startedAt       DateTime  @default(now())
  completedAt     DateTime?

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  task            Task?     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  goal            Goal?     @relation(fields: [goalId], references: [id], onDelete: SetNull)
  transactions    RewardTransaction[]

  @@index([userId])
  @@index([taskId])
  @@index([startedAt])
}

model Habit {
  id                  Int       @id @default(autoincrement())
  userId              Int
  title               String
  type                String
  trackingType        String    @default("discrete")
  frequency           String    @default("daily")
  timesPerDay         Int       @default(1)
  timesPerWeek        Int?
  currentStreak       Int       @default(0)
  bestStreak          Int       @default(0)
  startDate           DateTime?
  isDayTrackingEnabled Boolean  @default(false)
  createdAt           DateTime  @default(now())
  streakRestoredAt DateTime?

  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  logs                HabitLog[]

  @@index([userId])
}

model HabitLog {
  id         Int      @id @default(autoincrement())
  habitId    Int
  date       DateTime
  repetition Int      @default(1)
  note       String?
  createdAt  DateTime @default(now())

  habit      Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)

  @@unique([habitId, date, repetition])
  @@index([habitId])
  @@index([date])
}

model HabitTemplate {
  id       Int    @id @default(autoincrement())
  title    String
  type     String
  tracking String
  category String
  icon     String?
}

model Achievement {
  id       Int      @id @default(autoincrement())
  userId   Int
  type     String
  title    String
  description String  @default("")
  icon        String  @default("🏆")
  rarity      String  @default("common")
  createdAt DateTime  @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([userId, type]) 
  @@index([userId])
}

model RewardTransaction {
  id         Int      @id @default(autoincrement())
  userId     Int
  sessionId  Int?
  sourceType String
  sourceId   Int      @default(0)
  rewardType String
  amount     Float
  createdAt  DateTime @default(now())

  user       User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  session    PomodoroSession?  @relation(fields: [sessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
}

model InventoryItem {
  id         Int      @id @default(autoincrement())
  userId     Int
  itemType   String
  name       String
  rarity     String   @default("common")
  isActive   Boolean  @default(false)
  isEquipped Boolean  @default(false)
  source     String   @default("shop")
  price      Int?
  dropChance Float?
  assetUrl   String?
  earnedAt   DateTime @default(now())

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Friendship {
  id         Int      @id @default(autoincrement())
  senderId   Int
  receiverId Int
  status     String   @default("pending")
  createdAt  DateTime @default(now())

  sender     User     @relation("sender",   fields: [senderId],   references: [id], onDelete: Cascade)
  receiver   User     @relation("receiver", fields: [receiverId], references: [id], onDelete: Cascade)

  @@unique([senderId, receiverId])
  @@index([senderId])
  @@index([receiverId])
}

model WeeklyReport {
  id               Int      @id @default(autoincrement())
  userId           Int
  weekStart        DateTime
  weekEnd          DateTime
  totalPomodoroMin Int      @default(0)
  totalTasks       Int      @default(0)
  totalXp          Int      @default(0)
  totalGold        Int      @default(0)
  habitsRate       Float    @default(0)
  categoryData     Json     @default("{}")
  recommendations  Json     @default("[]")
  createdAt        DateTime @default(now())

  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, weekStart])
  @@index([userId])
}

model PomodoroSettings {
  id              Int  @id @default(autoincrement())
  userId          Int  @unique
  workDuration    Int  @default(25)
  shortBreak      Int  @default(5)
  longBreak       Int  @default(15)
  cyclesBeforeLong Int @default(4)

  user            User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Notification {
  id        Int      @id @default(autoincrement())
  userId    Int
  type      String   // 'friend_request' | 'task_due' | 'habit_reminder' | 'achievement'
  title     String
  body      String
  isRead    Boolean  @default(false)
  data      Json?    // дополнительные данные (taskId, habitId и т.д.)
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

// Активные временные бустеры
model ActiveBooster {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // 'xp_boost' | 'gold_boost' | 'combo_boost'
  multiplier  Float    @default(2.0)
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

// Постоянные перки (накапливаются, не истекают)
model PermanentPerk {
  id          Int      @id @default(autoincrement())
  userId      Int
  type        String   // 'xp_bonus' | 'gold_bonus'
  level       Int      @default(0)
  bonusPercent Float   // 10.0 = +10%
  isActive     Boolean @default(true)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, type]) // один перк каждого типа на пользователя
  @@index([userId])
}